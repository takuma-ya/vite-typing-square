<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="author" content="Takuma Yamashita">
    <link rel="icon" href="/images/typing-square.ico">
    <title>【Typing Square】音ゲー感覚で遊べるタイピングゲーム広場</title>
    <meta name="description" content="Typing Squareはリズムゲームの要素を組み込んだ無料のタイピングゲームです。音楽に沿ってランダムに流れてくるキーをタイミングよく叩いてハイスコアを目指そう！">

    <link href="/stylesheets/bootstrap.min.css" rel="stylesheet">
  </head>

<!-- Google tag (gtag.js) -->
<!--
<script async src="https://www.googletagmanager.com/gtag/js?id=G-9GMBD15D7C"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-9GMBD15D7C');
</script>
-->

<!-- https://ja.vitejs.dev/guide/backend-integration.html -->
<script type="module">
  import RefreshRuntime from 'http://localhost:3000/@react-refresh'
  RefreshRuntime.injectIntoGlobalHook(window)
  window.$RefreshReg$ = () => {}
  window.$RefreshSig$ = () => (type) => type
  window.__vite_plugin_react_preamble_installed__ = true
</script>

  <body>
    <main class="bg-body-secondary">
      <header class="d-flex flex-wrap justify-content-center py-3 mb-4 border-bottom" style="background-color: skyblue;">
        <!--<a href="/" class="d-flex align-items-center mb-3 mb-md-0 me-md-auto text-dark text-decoration-none">
          <img src="/images/logo.png">
        </a>-->
        <a href="/" style="width: 80%; text-align: center">
          <img src="/images/logo.png"style="width: 70%">
        </a>
        <!--
        <ul class="nav nav-pills">
          <li class="nav-item"><a href="#" class="nav-link active" aria-current="page">Home</a></li>
        </ul>
        -->
        
      </header>
      <div class="container">
        <div class="row">
          <div class="col-sm-10">
            <div class="mx-1 p-3 bg-body">
              <!--
              <div class="px-3 py-3 pt-md-5 pb-md-4 mx-auto text-center">
                <h1 class="display-4">楽曲一覧</h1>
                <p class="lead">遊ぶ曲を選んでね。</p>
              </div>-->
              <div id="root"></div>
            </div>
          </div>
          <div class="col-sm-2 bg-body">
            <div class="mx-1 p-3">
              <% if(isAuth) { %>
                <p>ようこそ、<%= userName %>さん</p>
                    <form action="logout" method="get">
                      <div class="text-end">
                        <button type="submit" class="btn btn-secondary btn-sm mb-4">ログアウト</button>
                      </div>
                    </form>
              <% } else { %>
                <p>ログインしているとスコアを保存できるよ！</p>
              <% } %>
              <form class="needs-validation" action="?" method="post">
                <label for="username" class="form-label">お名前</label>
                <input type="text" class="form-control mb-sm-2" id="username" name="username" placeholder="" value="" required="required">
                <!--<div class="invalid-feedback">
                  Valid name is required.
                </div>-->
                <label for="password" class="form-label">合言葉</label>
                <input type="text" class="form-control mb-sm-2" id="password" name="password" placeholder="" value="" required="required">
                <!-- <div class="invalid-feedback">
                  Valid password is required.
                </div>-->
                <div class="row">
                  <div class="col-sm-6 ">
                    <button type="submit" class="btn btn-success btn-sm" formaction="signup">新規登録</button>
                  </div>
                  <div class="col-sm-6">
                    <button type="submit" class="btn btn-primary btn-sm" formaction="signin">ログイン</button>
                  </div>
                </div>
              </form>
            </div>
            <% if (typeof errorMessage === 'undefined') { var errorMessage = []; } %>
            <% if(errorMessage.length != 0){ %>
              <div>
                <p><%= errorMessage %></p>
              </div>
            <% } %>
          </div>
        </div>
      </div>

     
      
      <div class="container-fluid bg-body">
        <footer class="py-3 my-4">
          <ul class="nav justify-content-center border-bottom pb-3 mb-3">
            <li class="nav-item"><a href="/credit" class="nav-link px-2 text-body-secondary">使用楽曲、およびイラストの詳細</a></li>
          </ul>
          <p class="text-center text-body-secondary">&copy; 2024 Typing Square</p>
        </footer>
      </div>

      <!-- Modal -->

      <div class="modal fade" id="game-modal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-fullscreen">
          <div class="modal-content">
            <div class="modal-header">
              <button type="button" class="btn-close" id="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="modal-body">
            </div>
          </div>
        </div>
      </div>

      <div class="modal fade" id="recordModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-fullscreen">
          <div class="modal-content">
            <div class="modal-header">
              <button type="button" class="btn-close" id="btn-close-record" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="modal-body-record">
            </div>
          </div>
        </div>
      </div>
    </main>


    <script src="javascripts/bootstrap.bundle.min.js"></script>
    <script src="//cdn.jsdelivr.net/npm/phaser@3.55.2/dist/phaser.min.js"></script>
    <script type="module" src="src/main.jsx"></script>
    <script src="javascripts/utils.js"></script>
    <script src="javascripts/record.js"></script>
      
  </body>
</html>
